<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

<!--    <bean id="alien" class="com.example.Alien" scope="prototype"></bean>-->
    <bean id = "alien" class = "com.example.Alien" autowire="byType">
<!--        Assigning the Value of Data Member this will Call Set Age Method -->
        <property name="age" value="10"></property>
<!--        <property name="computer" ref = "desktop"></property>-->
        <property name="pen" ref="pen"></property>

        <!--        <property name="laptop" ref="laptop"></property>-->
<!--        <constructor-arg value="100"></constructor-arg>-->
<!--        <constructor-arg ref="laptop"></constructor-arg>-->

    </bean>

    <bean id = "laptop" class="com.example.Laptop" primary="true"></bean>

    <bean id = "pen" class="com.example.Pen"></bean>

    <bean id = "computer" class="com.example.Desktop"></bean>
</beans>